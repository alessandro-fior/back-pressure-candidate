#!/bin/sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
REPO_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/../.." && pwd -P)
JDK_ROOT="$REPO_ROOT/.tooling/jdk"
JDK_RELEASE_TAG="jdk-21.0.10%2B7"
JDK_ARCHIVE_VERSION="21.0.10_7"

die() {
    printf 'error: %s\n' "$1" >&2
    exit 1
}

find_java_home() {
    for candidate in \
        "$JDK_ROOT"/jdk-*/Contents/Home \
        "$JDK_ROOT"/jdk-* \
        "$JDK_ROOT"/OpenJDK*/Contents/Home \
        "$JDK_ROOT"/OpenJDK* \
    ; do
        if [ -d "$candidate" ] && [ -x "$candidate/bin/java" ]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done

    return 1
}

if java_home=$(find_java_home); then
    printf '%s\n' "$java_home"
    exit 0
fi

command -v curl >/dev/null 2>&1 || die "curl is required to materialize the repo-local JDK 21 bootstrap."
command -v tar >/dev/null 2>&1 || die "tar is required to extract the repo-local JDK 21 bootstrap."

case "$(uname -s):$(uname -m)" in
    Darwin:arm64)
        jdk_archive="OpenJDK21U-jdk_aarch64_mac_hotspot_${JDK_ARCHIVE_VERSION}.tar.gz"
        ;;
    Darwin:x86_64)
        jdk_archive="OpenJDK21U-jdk_x64_mac_hotspot_${JDK_ARCHIVE_VERSION}.tar.gz"
        ;;
    Linux:x86_64)
        jdk_archive="OpenJDK21U-jdk_x64_linux_hotspot_${JDK_ARCHIVE_VERSION}.tar.gz"
        ;;
    Linux:aarch64|Linux:arm64)
        jdk_archive="OpenJDK21U-jdk_aarch64_linux_hotspot_${JDK_ARCHIVE_VERSION}.tar.gz"
        ;;
    *)
        die "Unsupported platform for automatic repo-local JDK bootstrap: $(uname -s) $(uname -m). Use tooling/scripts/dev instead."
        ;;
esac

mkdir -p "$JDK_ROOT"

jdk_url="https://github.com/adoptium/temurin21-binaries/releases/download/${JDK_RELEASE_TAG}/${jdk_archive}"
archive_path="$JDK_ROOT/$jdk_archive"
tmp_archive_path="$archive_path.tmp"

if [ ! -f "$archive_path" ]; then
    printf 'Bootstrapping repo-local JDK 21 from %s\n' "$jdk_url" >&2
    rm -f "$tmp_archive_path"
    curl -fsSL "$jdk_url" -o "$tmp_archive_path"
    mv "$tmp_archive_path" "$archive_path"
fi

printf 'Extracting repo-local JDK 21 into %s\n' "$JDK_ROOT" >&2
tar -xzf "$archive_path" -C "$JDK_ROOT"

if java_home=$(find_java_home); then
    printf '%s\n' "$java_home"
    exit 0
fi

die "The repo-local JDK 21 bootstrap was downloaded but no usable JAVA_HOME could be found afterward."
